# Generated per-machine by setup.sh
.gitconfig.local

# Session handoff notes (ephemeral, potentially sensitive)
claude/handoffs/

# One-off reports & migration notes — keep findings in PRs/issues, not as committed docs.
# Architectural decisions belong in ~/dev/claude-memory/pai-user/AISTEERINGRULES.md, not at repo root.
SECURITY_FINDINGS_*.md
*-HANDOFF.md

# Symlink artifacts (setup.sh creates these as symlinks in ~/.claude/)
.claude/

# Repo-local Codex/agent runtime state is generated and may contain private data.
# The tracked public-safe Codex dotfiles live in codex/ (no leading dot).
.codex/
.agents/
codex-memory/
.codex/auth.json
.codex/history.jsonl
.codex/logs_*.sqlite*
.codex/state_*.sqlite*
.codex/sessions/
.codex/shell_snapshots/
