[Unit]
Description=PAI Voice Server (ElevenLabs TTS notifications on :8888)
Documentation=https://github.com/jckeen/dotfiles
After=network.target

[Service]
Type=simple
WorkingDirectory=%h/.claude/VoiceServer
ExecStart=%h/.bun/bin/bun run %h/.claude/VoiceServer/server.ts
Restart=on-failure
RestartSec=5
StandardOutput=append:%h/.claude/VoiceServer/logs/voice-server.log
StandardError=append:%h/.claude/VoiceServer/logs/voice-server.log

# ─── Hardening ───────────────────────────────────────────────
# systemd directives do NOT accept inline `#` comments on the same line;
# every annotation below must live on its own line.

# Block setuid/setgid escalation.
NoNewPrivileges=true
# Private /tmp and /var/tmp for this unit.
PrivateTmp=true
# Entire FS becomes read-only except API filesystems (/proc, /sys) and ReadWritePaths.
ProtectSystem=strict
# $HOME stays readable (server reads user config) but is not writable by default.
ProtectHome=read-only
# Explicit writable paths under $HOME — the server appends to its own log file.
ReadWritePaths=%h/.claude/VoiceServer/logs
# TODO: verify ReadWritePaths covers all dirs the server writes (cache, temp uploads, etc.)
# Drop AF_NETLINK, AF_PACKET, raw sockets — keep only UNIX + IPv4/IPv6.
RestrictAddressFamilies=AF_UNIX AF_INET AF_INET6
# Forbid creating new user/mount/net/uts/ipc/pid/cgroup namespaces.
RestrictNamespaces=true
# Lock personality(2) — block legacy ABI / x86_32 emulation switching.
LockPersonality=true
# MemoryDenyWriteExecute is intentionally OMITTED — bun has a JIT that needs W+X pages.
# Whitelist common syscalls for typical services; everything else returns EPERM.
SystemCallFilter=@system-service
# Return EPERM for filtered syscalls (friendlier than SIGSYS for app-level handling).
SystemCallErrorNumber=EPERM

[Install]
WantedBy=default.target
